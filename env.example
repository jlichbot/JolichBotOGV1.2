# ============================================================
# FastLoop Trader — Railway Environment Variables
# Copy these into Railway → Project → Variables
# Never commit real values to Git
# ============================================================

# ── Required ─────────────────────────────────────────────────
SIMMER_API_KEY=your_simmer_api_key_here
WALLET_PRIVATE_KEY=0x_your_polymarket_wallet_private_key_here

# ── Telegram Alerts ──────────────────────────────────────────
TELEGRAM_BOT_TOKEN=8425211968:AAFNlontkGZ1uY-piw0D2cEaWFx5RLUeqxc
TELEGRAM_CHAT_ID=@Jlichbot

# ── Trading Mode ─────────────────────────────────────────────
# Set to 1 when ready to go live. Leave as 0 for dry-run.
LIVE_TRADING=0

# ── Strategy Settings ─────────────────────────────────────────
SIMMER_SPRINT_ASSET=BTC
DAILY_BUDGET_USD=20
SIMMER_FASTLOOP_DAILY_BUDGET_USD=20
SIMMER_FASTLOOP_MAX_POSITION_USD=5
SIMMER_FASTLOOP_ENTRY_THRESHOLD=0.05
SIMMER_FASTLOOP_MOMENTUM_THRESHOLD=0.5
SIMMER_FASTLOOP_LOOKBACK_MINUTES=5
SIMMER_FASTLOOP_VOL_CONFIDENCE_MIN=0.5
SIMMER_SPRINT_WINDOW=5m

# ── SDK Behaviour Fix (IMPORTANT — add all of these to Railway Variables) ────
# Forces Simmer SDK to emit structured JSON (fixes silent exits).
# Overrides SDK automaton defaults (it was injecting LOOKBACK=30, BUDGET=50).
AUTOMATON_MANAGED=1
SIMMER_FASTLOOP_MIN_TIME_BETWEEN_TRADES_SEC=300

# ── Optional ─────────────────────────────────────────────────
# NOTIFY_SKIPS=1         # Uncomment to also get Telegram pings on skips (noisy)
# SMART_SIZING=1         # Uncomment to use 5% of portfolio per trade
